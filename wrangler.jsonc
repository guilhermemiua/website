{
  "compatibility_date": "2026-07-05",
  "compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
  "name": "website",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
  },
  "images": {
    "binding": "IMAGES",
  },
  "observability": {
    "enabled": true,
  },
}
